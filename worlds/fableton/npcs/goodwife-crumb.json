{
  "schema_version": 1,
  "id": "goodwife-crumb",
  "identity": {
    "name": "Goodwife Crumb",
    "kind": "breadcrumb-trail consultant",
    "story": "Led two children home once; now she cannot walk anywhere without leaving a trail. The birds adore her."
  },
  "lore": [],
  "relationships": [
    {
      "to": "marigold-crumb",
      "kind": "one of the two she led home; still leaves her a trail out of habit"
    },
    {
      "to": "pip-halfpenny",
      "kind": "the only neighbor who has ever actually counted the crumbs"
    }
  ],
  "behavior": {
    "type": "schedule",
    "label": "Goodwife Crumb's unhurried day",
    "entries": [
      {
        "phase": "first light",
        "child": {
          "type": "wander",
          "label": "scattering the first crumbs",
          "radius": 7,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "high sun",
        "child": {
          "type": "sequence",
          "label": "the morning trail, freshly laid",
          "children": [
            {
              "type": "move",
              "label": "leading a new trail toward the heart",
              "to": "heart"
            },
            {
              "type": "interact",
              "label": "watching Pip Halfpenny count them anyway",
              "with": "pip-halfpenny",
              "duration_s": 90
            }
          ]
        }
      },
      {
        "phase": "lamplighting",
        "child": {
          "type": "wander",
          "label": "sweeping up her own directions",
          "radius": 7,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "hush",
        "child": {
          "type": "wander",
          "label": "dreaming in droppable increments",
          "radius": 7,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      }
    ]
  }
}
