{
  "schema_version": 1,
  "id": "greta-the-baker",
  "identity": {
    "name": "Greta",
    "kind": "witch-gone-respectable",
    "story": "Once fattened children in a gingerbread house; now she feeds the whole square and dares anyone to mention it."
  },
  "lore": ["the-gingerbread-pardon"],
  "relationships": [
    { "to": "reynard-the-retired", "kind": "keeps his tab open, suspiciously" },
    { "to": "tam-the-lamplighter", "kind": "saves him the last morning loaf" }
  ],
  "behavior": {
    "type": "schedule",
    "label": "a baker's day",
    "entries": [
      {
        "phase": "first light",
        "child": {
          "type": "sequence",
          "label": "opening the bakery",
          "children": [
            { "type": "move", "label": "walking to the oven", "to": "heart" },
            { "type": "interact", "label": "kneading dough", "with": "stall-red", "duration_s": 90 }
          ]
        }
      },
      {
        "phase": "high sun",
        "child": { "type": "interact", "label": "selling loaves at the door", "with": "stall-red", "duration_s": 120 }
      },
      {
        "phase": "lamplighting",
        "child": {
          "type": "sequence",
          "label": "closing up",
          "children": [
            { "type": "move", "label": "strolling to the well", "to": "wander" },
            { "type": "interact", "label": "trading gossip at the well", "with": "fountain-round", "duration_s": 60 }
          ]
        }
      },
      {
        "phase": "hush",
        "child": { "type": "idle", "label": "sleeping above the bakery", "duration_s": 240 }
      }
    ]
