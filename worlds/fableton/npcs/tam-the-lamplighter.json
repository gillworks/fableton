{
  "schema_version": 1,
  "id": "tam-the-lamplighter",
  "identity": {
    "name": "Tam",
    "kind": "woodcutter's-son-turned-lamplighter",
    "story": "His tale ended one line before the ever after; he lights the lamps so nobody else's ending gets lost in the dark."
  },
  "lore": [
    "the-unfinished-line"
  ],
  "relationships": [
    {
      "to": "greta-the-baker",
      "kind": "first customer, every morning"
    },
    {
      "to": "ember-wick",
      "kind": "saves him every candle-end in town"
    },
    {
      "to": "vesper",
      "kind": "the bell that tells him he's on time"
    }
  ],
  "behavior": {
    "type": "schedule",
    "label": "a lamplighter's day",
    "entries": [
      {
        "phase": "first light",
        "child": {
          "type": "sequence",
          "label": "morning rounds",
          "children": [
            {
              "type": "move",
              "label": "crossing to the bakery",
              "to": "heart"
            },
            {
              "type": "interact",
              "label": "buying the first loaf",
              "with": "stall-red",
              "duration_s": 20
            }
          ]
        }
      },
      {
        "phase": "high sun",
        "child": {
          "type": "sequence",
          "label": "a nap Greta won't let finish",
          "children": [
            {
              "type": "idle",
              "label": "dozing on the well's rim",
              "duration_s": 90
            },
            {
              "type": "interact",
              "label": "waking for the roll she brings anyway",
              "with": "stall-red",
              "duration_s": 20
            }
          ]
        }
      },
      {
        "phase": "lamplighting",
        "child": {
          "type": "sequence",
          "label": "the lighting of the lamps",
          "children": [
            {
              "type": "move",
              "label": "walking his lamp route",
              "to": "heart"
            },
            {
              "type": "interact",
              "label": "lighting the square lamp",
              "with": "lantern",
              "duration_s": 15
            }
          ]
        }
      },
      {
        "phase": "hush",
        "child": {
          "type": "sequence",
          "label": "holding the lamp over the first course",
          "children": [
            {
              "type": "move",
              "label": "walking past the lit square to the stone going in",
              "to": "bridge-plot"
            },
            {
              "type": "interact",
              "label": "steadying the cart so she doesn't have to",
              "with": "cart",
              "duration_s": 60
            },
            {
              "type": "idle",
              "label": "keeping the match dry for the stone that isn't laid yet",
              "duration_s": 160
            }
          ]
        }
      }
    ]
  }
}
