{
  "schema_version": 1,
  "id": "the-lesser-piper",
  "identity": {
    "name": "The Lesser Piper",
    "kind": "piper (rats only, licensed)",
    "story": "Cousin of the famous one. Strictly rodents, strictly contracted, references available on request."
  },
  "lore": [],
  "relationships": [
    {
      "to": "tick",
      "kind": "insists clockwork is outside his contract"
    },
    {
      "to": "the-miller-who-never-paid",
      "kind": "collects on a debt he didn't earn, at his own rate, and has never once said it isn't his to collect"
    }
  ],
  "behavior": {
    "type": "schedule",
    "label": "The Lesser Piper's rounds, rats only, strictly",
    "entries": [
      {
        "phase": "first light",
        "child": {
          "type": "sequence",
          "label": "tuning directly under the complaint",
          "children": [
            {
              "type": "move",
              "label": "setting up beneath Tick's favorite window",
              "to": "heart"
            },
            {
              "type": "idle",
              "label": "tuning the work pipe, allegedly by coincidence, exactly where Tick can hear it",
              "duration_s": 45
            }
          ]
        }
      },
      {
        "phase": "high sun",
        "child": {
          "type": "wander",
          "label": "making his rounds, pied slightly",
          "radius": 6,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "lamplighting",
        "child": {
          "type": "wander",
          "label": "piping the evening scales",
          "radius": 6,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "hush",
        "child": {
          "type": "sequence",
          "label": "totting up the debt before he sleeps",
          "children": [
            {
              "type": "move",
              "label": "circling back past the stall",
              "to": "heart"
            },
            {
              "type": "interact",
              "label": "chalking this month's rat count on the stall board, complaint from Tick or no complaint from Tick",
              "with": "stall",
              "duration_s": 45
            }
          ]
        }
      }
    ]
  }
}
