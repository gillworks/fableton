              "to": "heart"
            },
            {
              "type": "interact",
              "label": "measuring out one reasonable bowl, counted twice out of habit, the fair pledge long since crossed off",
              "with": "stall",
              "duration_s": 60
            }
          ]
        }
      },
      {
        "phase": "lamplighting",
        "child": {
          "type": "sequence",
          "label": "cooling his handles, under supervision",
          "children": [
            {
              "type": "move",
              "label": "wheeling over to the flat rock",
              "to": "heart"
            },
            {
              "type": "interact",
