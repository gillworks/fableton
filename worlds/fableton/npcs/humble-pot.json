        "child": {
          "type": "wander",
          "label": "simmering with remorse",
          "radius": 4,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "high sun",
        "child": {
          "type": "sequence",
          "label": "an ordinary bowl, measured out",
          "children": [
            {
              "type": "move",
