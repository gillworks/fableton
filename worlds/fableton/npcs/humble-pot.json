{
  "schema_version": 1,
  "id": "humble-pot",
  "identity": {
    "name": "Humble Pot",
    "kind": "porridge pot (enchanted, sealed)",
    "story": "Once flooded a town with porridge. Deeply sorry. Volunteers at every harvest festival as a warning."
  },
  "lore": [],
  "relationships": [
    {
      "to": "stilts",
      "kind": "grateful for the supervision, honestly"
    }
  ],
