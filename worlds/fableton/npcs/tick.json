{
  "schema_version": 1,
  "id": "tick",
  "identity": {
    "name": "Tick",
    "kind": "clockwork mouse",
    "story": "Escaped a nursery story with most of his springs. Winds himself now, thank you."
  },
  "lore": [],
  "relationships": [
    {
      "to": "the-lesser-piper",
      "kind": "files a complaint every time the piper practices"
    }
  ],
  "behavior": {
    "type": "schedule",
    "label": "Tick's springs, wound by his own hand",
    "entries": [
      {
        "phase": "first light",
        "child": {
          "type": "sequence",
          "label": "the morning complaint, filed on schedule",
          "children": [
            {
              "type": "move",
              "label": "marching to the square to lodge it",
              "to": "heart"
            },
            {
              "type": "interact",
              "label": "filing today's complaint straight at the piper, same as every dawn, in person this time",
              "with": "the-lesser-piper",
              "duration_s": 45
            }
          ]
        }
      },
      {
        "phase": "high sun",
        "child": {
          "type": "wander",
          "label": "timing the square's comings and goings",
          "radius": 5,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "lamplighting",
        "child": {
          "type": "wander",
          "label": "ticking down for the evening",
          "radius": 5,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "hush",
        "child": {
          "type": "wander",
          "label": "parked, fully wound, just in case",
          "radius": 5,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      }
    ]
  }
}
