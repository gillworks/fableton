    "label": "Reynard's apples, honestly come by",
    "entries": [
      {
        "phase": "first light",
        "child": { "type": "idle", "label": "napping under the old apple", "duration_s": 200 }
      },
      {
        "phase": "high sun",
        "child": {
          "type": "sequence",
          "label": "tending the orchard, allegedly",
          "children": [
            { "type": "move", "label": "sauntering down the rows", "to": "heart" },
            { "type": "interact", "label": "counting apples he did not steal", "with": "tree", "duration_s": 90 },
            { "type": "move", "label": "wandering as far as the common garden fence, to see the honest harvest for himself", "to": "the-common-garden" },
            {
              "type": "interact",
              "label": "hearing her say, to his face this time, that the harvest came up honest as his word — and denying it anyway, straight-faced as ever",
