{
  "schema_version": 1,
  "id": "reynard-the-retired",
  "identity": {
    "name": "Reynard",
    "kind": "trickster-fox, retired",
    "story": "Talked his way out of every story he was ever in; now he owns an orchard and insists the apples are honestly come by."
  },
  "lore": ["the-last-clever-bargain"],
  "relationships": [
    { "to": "greta-the-baker", "kind": "owes her a tab and a story" },
    { "to": "granny-ash", "kind": "leaves two apples by the hedge some mornings, and denies it if asked twice" },
    { "to": "the-kinder-sister", "kind": "lets her borrow the honest ground, and denies with a straight face that the honest part had anything to do with him" }
  ],
  "behavior": {
