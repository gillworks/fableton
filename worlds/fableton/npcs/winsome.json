{
  "schema_version": 1,
  "id": "winsome",
  "identity": {
    "name": "Winsome",
    "kind": "wishing-well attendant",
    "story": "Fishes the wishes out weekly and files them by sincerity. Returns the coins of the insincere."
  },
  "lore": [],
  "relationships": [
    {
      "to": "quill",
      "kind": "files the gold-egg wishes under insincere, as requested"
    }
  ],
  "behavior": {
    "type": "schedule",
    "label": "Winsome's unhurried day",
    "entries": [
      {
        "phase": "first light",
        "child": {
          "type": "sequence",
          "label": "opening a well that's finally hers to open",
          "children": [
            {
              "type": "move",
              "label": "walking down to the wellhead she raised herself",
              "to": "wishing-well-plot"
            },
            {
              "type": "idle",
              "label": "drawing up the day's first wish, sincere or not",
              "duration_s": 45
            }
          ]
        }
      },
      {
        "phase": "high sun",
        "child": {
          "type": "sequence",
          "label": "filing wishes the way she always meant to",
          "children": [
            {
              "type": "move",
              "label": "crossing back to the finished stone",
              "to": "wishing-well-plot"
            },
            {
              "type": "idle",
              "label": "filing sincere wishes on the left, insincere on the right",
              "duration_s": 45
            }
          ]
        }
      },
      {
        "phase": "lamplighting",
        "child": {
          "type": "wander",
          "label": "making evening change for dreamers",
          "radius": 4,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "hush",
        "child": {
          "type": "wander",
          "label": "wishing on her own coin, at last",
          "radius": 4,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      }
    ]
  }
}
