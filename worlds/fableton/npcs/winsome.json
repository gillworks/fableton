{
  "schema_version": 1,
  "id": "winsome",
  "identity": {
    "name": "Winsome",
    "kind": "wishing-well attendant",
    "story": "Fishes the wishes out weekly and files them by sincerity. Returns the coins of the insincere."
  },
  "lore": [],
  "relationships": [
    {
      "to": "quill",
      "kind": "files the gold-egg wishes under insincere, as requested"
    }
  ],
  "behavior": {
    "type": "schedule",
    "label": "Winsome's unhurried day",
    "entries": [
      {
        "phase": "first light",
        "child": {
          "type": "sequence",
          "label": "answering the shaft before the wishes do",
          "children": [
            {
              "type": "move",
              "label": "walking down to the plot everyone's been stepping around",
              "to": "wishing-well-plot"
            },
            {
              "type": "idle",
              "label": "sinking the well's shaft, one careful foot at a time",
              "duration_s": 45
            }
          ]
        }
      },
      {
        "phase": "high sun",
        "child": {
          "type": "sequence",
          "label": "raising what she's tended in spirit for years",
          "children": [
            {
              "type": "move",
              "label": "crossing back to the marked plot",
              "to": "wishing-well-plot"
            },
            {
              "type": "idle",
              "label": "setting stone for a wellhead she's been imagining since before it existed",
              "duration_s": 45
            }
          ]
        }
      },
      {
        "phase": "lamplighting",
        "child": {
          "type": "wander",
          "label": "making evening change for dreamers",
          "radius": 4,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "hush",
        "child": {
          "type": "wander",
          "label": "wishing, once, on her own coin",
          "radius": 4,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      }
    ]
  }
}
