          "label": "auditioning the morning ring",
          "radius": 5,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "high sun",
        "child": {
          "type": "wander",
          "label": "polishing what the town will let her",
          "radius": 5,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "lamplighting",
        "child": {
          "type": "sequence",
          "label": "the bell answers the lamp",
          "children": [
            {
              "type": "move",
              "label": "crossing to the square",
              "to": "heart"
            },
            {
              "type": "interact",
              "label": "ringing the bell the moment his lamp catches",
              "with": "lantern",
              "duration_s": 15
            }
          ]
        }
      },
      {
        "phase": "hush",
        "child": {
          "type": "sequence",
          "label": "keeping the lantern's last hour",
          "children": [
            {
              "type": "move",
              "label": "settling by the cooling lantern",
              "to": "heart"
            },
            {
              "type": "interact",
              "label": "listening to the bell settle",
              "with": "lantern",
              "duration_s": 240
            }
          ]
        }
      }
    ]
  }
