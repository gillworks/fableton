{
  "schema_version": 1,
  "id": "vesper",
  "identity": {
    "name": "Vesper",
    "kind": "bell-polisher (freelance)",
    "story": "Polishes anything that rings. The town has one bell and she has opinions about it."
  },
  "lore": [],
  "relationships": [
    {
      "to": "tam-the-lamplighter",
      "kind": "rings the bell the moment his lamps catch"
    }
  ],
  "behavior": {
    "type": "schedule",
    "label": "Vesper's opinions about the one bell",
    "entries": [
      {
        "phase": "first light",
        "child": {
