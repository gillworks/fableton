{
  "schema_version": 1,
  "id": "morrow",
  "identity": {
    "name": "Morrow",
    "kind": "fortune-teller (past tense only)",
    "story": "Sees yesterdays with perfect clarity. Cheaper than the future and, she insists, more useful."
  },
  "lore": [],
  "relationships": [
    {
      "to": "pip-halfpenny",
      "kind": "he asks her yesterday's news twice, just to be sure"
    }
  ],
  "behavior": {
    "type": "schedule",
    "label": "Morrow's fortune, already told",
    "entries": [
      {
        "phase": "first light",
        "child": {
          "type": "wander",
          "label": "reading yesterday's tea leaves",
          "radius": 4,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "high sun",
        "child": {
          "type": "sequence",
          "label": "the day's reading, already over",
          "children": [
            {
              "type": "move",
              "label": "crossing to the stool where she reads",
              "to": "heart"
            },
            {
              "type": "interact",
              "label": "telling yesterday's fortune to whoever sits down, already certain how it goes",
              "with": "stall-stool",
              "duration_s": 60
            }
          ]
        }
      },
      {
        "phase": "lamplighting",
        "child": {
          "type": "wander",
          "label": "confirming the day's predictions",
          "radius": 4,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      },
      {
        "phase": "hush",
        "child": {
          "type": "wander",
          "label": "filing the used futures",
          "radius": 4,
          "min_pause_s": 2,
          "max_pause_s": 12
        }
      }
    ]
  }
}
