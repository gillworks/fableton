{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "engine-serve",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "FABLETON_REPO_URL=https://github.com/gillworks/fableton",
        "pnpm",
        "--dir",
        "engine",
        "exec",
        "tsx",
        "src/api/cli.ts",
        "--charter",
        "../charters/fableton/charter.yaml",
        "--world",
        "../worlds/fableton"
      ],
      "port": 8091
    },
    {
      "name": "client",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "FABLETON_WORLD=worlds/fableton",
        "pnpm",
        "--dir",
        "client",
        "dev"
      ],
      "port": 8080
    },
    {
      "name": "stack-cindervault",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "FABLETON_CHARTER=charters/cindervault/charter.yaml",
        "docker",
        "compose",
        "-f",
        "deploy/compose.yaml",
        "up"
      ],
      "port": 8080
    },
    {
      "name": "stack-skeinsea",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "FABLETON_CHARTER=charters/skeinsea/charter.yaml",
        "docker",
        "compose",
        "-f",
        "deploy/compose.yaml",
        "up"
      ],
      "port": 8080
    },
    {
      "name": "stack",
      "runtimeExecutable": "docker",
      "runtimeArgs": [
        "compose",
        "-f",
        "deploy/compose.yaml",
        "up"
      ],
      "port": 8080
    }
  ]
}
