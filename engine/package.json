{
  "name": "@fableton/engine",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./color": "./src/color.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate": "tsx src/validate/cli.ts --charter ../charters/_template/charter.yaml --world test/fixtures/sample-world && tsx src/validate/checkRegistry.ts --charter ../charters/_template/charter.yaml --registry ../assets/registry.json",
    "sim": "tsx src/sim/cli.ts --charter ../charters/_template/charter.yaml --world test/fixtures/sample-world",
    "serve": "tsx src/api/cli.ts --charter ../charters/_template/charter.yaml --world test/fixtures/sample-world"
  },
  "dependencies": {
    "ws": "^8.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
