# SPDX-License-Identifier: Apache-2.0
#
# Bring-your-own-keys (CLAUDE.md): copy to .env (gitignored) and fill in.
# Real environment variables take precedence over this file.

# Required for the Founding Session (studio: pnpm found)
ANTHROPIC_API_KEY=

# Model tier overrides (docs/architecture.md — defaults shown)
GOD_MODEL=claude-fable-5
# STEWARD_MODEL=claude-sonnet-5   # Phase B
# SPRITE_MODEL=claude-haiku-4-5   # Phase B

# Deploy (docker compose — see deploy/README.md)
# FABLETON_PORT=8080                                  # public port for the world
# FABLETON_CHARTER=charters/_template/charter.yaml    # image-relative charter path
# POSTGRES_PASSWORD=fableton                          # in-stack postgres
# DATABASE_URL=                                       # set to use an external postgres instead

# Wish intake (issue #79) — the viewer source of the feedback funnel.
# Unset: the in-client wish box reports "wishes are closed" (v1 default).
# Set a token with issues:write and wishes file to the world repo backlog
# as GitHub issues labeled `wish`.
# FABLETON_WISH_TOKEN=                                # GitHub token; enables intake. Least privilege
#                                                     # (issue #101): a FINE-GRAINED token with Issues
#                                                     # read/write on the backlog repo ONLY — this token
#                                                     # sits behind a public write path, so scope it as
#                                                     # if it will leak.
# FABLETON_WISH_REPO=gillworks/fableton               # target owner/repo; falls back to FABLETON_REPO_URL
